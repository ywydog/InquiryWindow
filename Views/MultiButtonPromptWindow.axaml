<ci:MyWindow x:Class="InquiryWindow.Views.MultiButtonPromptWindow"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:models="clr-namespace:InquiryWindow.Models"
             xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
             xmlns:helpers="clr-namespace:ClassIsland.Core.Helpers;assembly=ClassIsland.Core"
             Width="500" Height="280"
             MinHeight="220" MinWidth="360"
             WindowStartupLocation="CenterScreen"
             CanResize="True"
             Topmost="True"
             ShowAsDialog="True">

    <ci:MyWindow.Styles>
        <!-- ClassIsland 自带的 Markdown 主题，让弹窗和系统设置/更新日志风格一致 -->
        <StyleInclude Source="avares://ClassIsland.Core/Themes/RichTextStyles.axaml" />
    </ci:MyWindow.Styles>

    <Border Padding="20" CornerRadius="8"
            Background="{DynamicResource LayerFillColorAltBrush}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">

            <!-- 主提示（Markdown 渲染：仅上下滚动，横向强制关闭） -->
            <mdxaml:MarkdownScrollViewer Grid.Row="0"
                                          Engine="{x:Static helpers:MarkdownConvertHelper.Engine}"
                                          Markdown="{Binding Prompt}"
                                          MinHeight="40"
                                          MaxHeight="160" />

            <!-- 副提示（Markdown 渲染，可见性由是否非空控制） -->
            <mdxaml:MarkdownScrollViewer Grid.Row="1"
                                          Engine="{x:Static helpers:MarkdownConvertHelper.Engine}"
                                          Markdown="{Binding SubPrompt}"
                                          IsVisible="{Binding SubPrompt, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                          MinHeight="32"
                                          MaxHeight="100" />

            <!-- 倒计时（文本 + 进度条），仅在自动执行启用时显示 -->
            <Border Grid.Row="2"
                    Padding="12"
                    CornerRadius="6"
                    IsVisible="{Binding IsAutoExecuteActive}"
                    Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding CountdownText}"
                               FontSize="14"
                               FontWeight="DemiBold" />
                    <ProgressBar Height="5"
                                 Minimum="0"
                                 Maximum="{Binding AutoExecuteMaxSeconds}"
                                 Value="{Binding AutoExecuteRemainingSeconds}">
                        <ProgressBar.Styles>
                            <Style Selector="ProgressBar">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Style>
                        </ProgressBar.Styles>
                    </ProgressBar>
                </StackPanel>
            </Border>

            <!-- 按钮列表（运行时由 ViewModel 动态填入） -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding Buttons}" Margin="0,4,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10"
                                    HorizontalAlignment="Right" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:MultiButtonPromptButton">
                        <Button MinWidth="96" Height="34"
                                Classes="accent"
                                Command="{Binding $parent[Window].DataContext.PressButtonCommand}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="{DynamicResource FluentIcons}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>
    </Border>
</ci:MyWindow>
