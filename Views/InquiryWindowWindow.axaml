<ci:MyWindow x:Class="InquiryWindow.Views.InquiryWindowWindow"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             xmlns:local="clr-namespace:InquiryWindow.Views"
             xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
             xmlns:helpers="clr-namespace:ClassIsland.Core.Helpers;assembly=ClassIsland.Core"
             Width="500" Height="240"
             MinHeight="200"
             WindowStartupLocation="CenterScreen"
             CanResize="False"
             Topmost="True"
             ShowAsDialog="True">

    <ci:MyWindow.Styles>
        <!-- ClassIsland 自带的 Markdown 主题，让弹窗和系统设置/更新日志风格一致 -->
        <StyleInclude Source="avares://ClassIsland.Core/Themes/RichTextStyles.axaml" />
    </ci:MyWindow.Styles>

    <!--
        根 Border。
        Background 留空，由 code-behind 根据"亚克力背景"开关动态填充：
          开启时：半透明刷（SystemControlBackgroundChromeMediumLowBrush），让窗口亚克力基底透出来
          关闭时：默认的 LayerFillColorAltBrush（不透明卡片）
        这样在不动 XAML 的前提下能切换视觉风格。
    -->
    <Border x:Name="RootBorder" Padding="16" CornerRadius="8">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" RowSpacing="8">

            <!-- 弹窗标题小字（窗口内顶部） -->
            <TextBlock Grid.Row="0"
                       Text="{Binding DialogTitleSmall}"
                       FontSize="14"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <!-- 主标题 + 图标（图标的可见性由 ShowIcon 控制） -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
                <Image Source="{Binding Icon}"
                       Width="32" Height="32"
                       IsVisible="{Binding IsIconVisible}" />
                <TextBlock Text="{Binding DialogTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- 正文（Markdown 渲染：仅上下滚动，横向强制关闭） -->
            <mdxaml:MarkdownScrollViewer Grid.Row="2"
                                          Engine="{x:Static helpers:MarkdownConvertHelper.Engine}"
                                          Markdown="{Binding DialogBody}"
                                          MinHeight="40"
                                          MaxHeight="320"
                                          VerticalAlignment="Top" />

            <!-- 路径预览（独立一行，可见性由 ShowPath 控制） -->
            <TextBlock Grid.Row="3"
                       Text="{Binding PathText}"
                       FontFamily="Consolas, Menlo, monospace"
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding IsPathVisible}" />

            <!-- 倒计时（文本 + 进度条），仅在自动执行启用时显示 -->
            <Border Grid.Row="4"
                    Padding="12"
                    CornerRadius="6"
                    IsVisible="{Binding IsAutoExecuteActive}"
                    Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding CountdownText}"
                               FontSize="14"
                               FontWeight="DemiBold" />
                    <ProgressBar Height="5"
                                 Minimum="0"
                                 Maximum="{Binding AutoExecuteMaxSeconds}"
                                 Value="{Binding AutoExecuteRemainingSeconds}">
                        <ProgressBar.Styles>
                            <Style Selector="ProgressBar">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Style>
                        </ProgressBar.Styles>
                    </ProgressBar>
                </StackPanel>
            </Border>

            <!-- 按钮（右对齐：取消在左，执行在右） -->
            <Grid Grid.Row="5" ColumnDefinitions="*,Auto,Auto">
                <Button Grid.Column="1"
                        Content="取消"
                        MinWidth="84"
                        Height="33"
                        Margin="0,0,8,0"
                        Click="OnCancelClick" />
                <Button Grid.Column="2"
                        Content="执行"
                        Classes="accent"
                        IsDefault="True"
                        MinWidth="84"
                        Height="33"
                        IsEnabled="{Binding CanExecute}"
                        Click="OnExecuteClick" />
            </Grid>

        </Grid>
    </Border>
</ci:MyWindow>
