<ci:ActionSettingsControlBase x:Class="InquiryWindow.Views.MultiButtonPromptSettingsControl"
                              x:TypeArguments="settings:MultiButtonPromptSettings"
                              xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:ci="http://classisland.tech/schemas/xaml/core"
                              xmlns:core="clr-namespace:ClassIsland.Core.Controls.Automation;assembly=ClassIsland.Core"
                              xmlns:settings="clr-namespace:InquiryWindow.Models"
                              xmlns:local="clr-namespace:InquiryWindow.Views"
                              xmlns:models="clr-namespace:InquiryWindow.Models"
                              xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
                              xmlns:helpers="clr-namespace:ClassIsland.Core.Helpers;assembly=ClassIsland.Core">

    <ci:ActionSettingsControlBase.Styles>
        <!-- 让预览和实际弹窗用同一套 Markdown 主题 -->
        <StyleInclude Source="avares://ClassIsland.Core/Themes/RichTextStyles.axaml" />
    </ci:ActionSettingsControlBase.Styles>

    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:MultiButtonPromptSettingsControl}}">
    <ScrollViewer>
        <StackPanel Margin="12" Spacing="12">

            <StackPanel Spacing="4">
                <TextBlock Text="窗口标题 (OS 标题栏)" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBox Text="{Binding Settings.Title, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="主提示文本（支持 Markdown）" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBox Text="{Binding Settings.Prompt, Mode=TwoWay}" />
                <!-- 预览：实时反映主提示 Markdown 渲染结果 -->
                <Border Margin="0,4,0,0" Padding="8" CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="预览" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <mdxaml:MarkdownScrollViewer
                            Engine="{x:Static helpers:MarkdownConvertHelper.Engine}"
                            Markdown="{Binding Settings.Prompt}"
                            MaxHeight="120" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="副提示文本（可空，支持 Markdown）" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBox Text="{Binding Settings.SubPrompt, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="60" />
                <!-- 预览：副提示非空时显示 -->
                <Border Margin="0,4,0,0" Padding="8" CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        IsVisible="{Binding Settings.SubPrompt, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="预览" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <mdxaml:MarkdownScrollViewer
                            Engine="{x:Static helpers:MarkdownConvertHelper.Engine}"
                            Markdown="{Binding Settings.SubPrompt}"
                            MaxHeight="100" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Text="按钮" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0" />

            <ItemsControl ItemsSource="{Binding Settings.Buttons}"
                          DragDrop.AllowDrop="True"
                          DragDrop.DragOver="OnButtonListDragOver"
                          DragDrop.Drop="OnButtonListDrop">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:MultiButtonPromptButton">
                        <Expander Margin="0,4" HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  DragDrop.AllowDrop="True"
                                  DragDrop.DragOver="OnButtonItemDragOver"
                                  DragDrop.Drop="OnButtonItemDrop">
                            <Expander.Header>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <!-- 拖拽手柄：仅作为 PointerPressed 起点，视觉上提示可拖 -->
                                    <Border Grid.Column="0"
                                            Tag="{Binding}"
                                            Padding="6,2"
                                            CornerRadius="4"
                                            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                            Cursor="Hand"
                                            PointerPressed="OnButtonDragHandlePressed"
                                            PointerMoved="OnButtonDragHandleMoved"
                                            PointerReleased="OnButtonDragHandleReleased"
                                            ToolTip.Tip="按住拖动以排序">
                                        <TextBlock Text="⋮⋮"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{DynamicResource FluentIcons}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <TextBox Grid.Column="0"
                                             Watermark="按钮名称"
                                             Text="{Binding Name, Mode=TwoWay}" />
                                    <TextBox Grid.Column="1"
                                             Watermark="图标字符"
                                             Text="{Binding Icon, Mode=TwoWay}"
                                             Margin="8,0,0,0"
                                             Width="80" />
                                    <Button Grid.Column="2"
                                            Content="…"
                                            Margin="4,0,0,0"
                                            Click="OnPickIconClick"
                                            Tag="{Binding}"
                                            ToolTip.Tip="从 Fluent 图标库选择" />
                                    <Button Grid.Column="3"
                                            Content="从预设插入"
                                            Margin="4,0,0,0"
                                            Click="OnInsertPresetClick"
                                            Tag="{Binding}" />
                                </Grid>
                                <core:ActionControl ActionSet="{Binding Actions}" />
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ 添加按钮"
                    Click="OnAddButtonClick"
                    HorizontalAlignment="Left" />

        </StackPanel>
    </ScrollViewer>
    </Grid>
</ci:ActionSettingsControlBase>
