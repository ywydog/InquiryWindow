<ci:ActionSettingsControlBase x:Class="InquiryWindow.Views.MultiButtonPromptSettingsControl"
                              x:TypeArguments="settings:MultiButtonPromptSettings"
                              xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:ci="http://classisland.tech/schemas/xaml/core"
                              xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                              xmlns:core="clr-namespace:ClassIsland.Core.Controls.Automation;assembly=ClassIsland.Core"
                              xmlns:settings="clr-namespace:InquiryWindow.Models"
                              xmlns:local="clr-namespace:InquiryWindow.Views"
                              xmlns:models="clr-namespace:InquiryWindow.Models">

    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:MultiButtonPromptSettingsControl}}">
    <ScrollViewer>
        <StackPanel Margin="12" Spacing="12">

            <StackPanel Spacing="4">
                <TextBlock Text="窗口标题 (OS 标题栏)" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBox Text="{Binding Settings.Title, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="主提示文本（支持 Markdown）" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Button Grid.Column="1"
                            Content="预览..."
                            Click="OnPreviewPromptClick"
                            Padding="10,2"
                            FontSize="11" />
                </Grid>
                <TextBox Text="{Binding Settings.Prompt, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="副提示文本（可空，支持 Markdown）" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Button Grid.Column="1"
                            Content="预览..."
                            Click="OnPreviewSubPromptClick"
                            Padding="10,2"
                            FontSize="11" />
                </Grid>
                <TextBox Text="{Binding Settings.SubPrompt, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="60" />
            </StackPanel>

            <TextBlock Text="按钮" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0" />

            <ItemsControl ItemsSource="{Binding Settings.Buttons}"
                          DragDrop.AllowDrop="True"
                          DragDrop.DragOver="OnButtonListDragOver"
                          DragDrop.Drop="OnButtonListDrop">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:MultiButtonPromptButton">
                        <Expander Margin="0,4" HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  DragDrop.AllowDrop="True"
                                  DragDrop.DragOver="OnButtonItemDragOver"
                                  DragDrop.Drop="OnButtonItemDrop">
                            <Expander.Header>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <!-- 拖拽手柄：仅作为 PointerPressed 起点，视觉上提示可拖 -->
                                    <Border Grid.Column="0"
                                            Tag="{Binding}"
                                            Padding="6,2"
                                            CornerRadius="4"
                                            Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                            Cursor="Hand"
                                            PointerPressed="OnButtonDragHandlePressed"
                                            PointerMoved="OnButtonDragHandleMoved"
                                            PointerReleased="OnButtonDragHandleReleased"
                                            ToolTip.Tip="按住拖动以排序">
                                        <TextBlock Text="⋮⋮"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{DynamicResource FluentIcons}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <TextBox Grid.Column="0"
                                             Watermark="按钮名称"
                                             Text="{Binding Name, Mode=TwoWay}" />
                                    <TextBox Grid.Column="1"
                                             Watermark="图标字符"
                                             Text="{Binding Icon, Mode=TwoWay}"
                                             Margin="8,0,0,0"
                                             Width="80" />
                                    <Button Grid.Column="2"
                                            Content="…"
                                            Margin="4,0,0,0"
                                            Click="OnPickIconClick"
                                            Tag="{Binding}"
                                            ToolTip.Tip="从 Fluent 图标库选择" />
                                    <Button Grid.Column="3"
                                            Content="从预设插入"
                                            Margin="4,0,0,0"
                                            Click="OnInsertPresetClick"
                                            Tag="{Binding}" />
                                </Grid>
                                <core:ActionControl ActionSet="{Binding Actions}" />
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ 添加按钮"
                    Click="OnAddButtonClick"
                    HorizontalAlignment="Left" />

            <!-- 自动执行（默认关闭） -->
            <StackPanel Spacing="6" Margin="0,8,0,0">
                <CheckBox x:Name="AutoExecuteCheck"
                          Content="在弹窗显示后自动触发"
                          IsChecked="{Binding Settings.IsAutoExecuteEnabled, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="24,0,0,0"
                            IsEnabled="{Binding #AutoExecuteCheck.IsChecked}">
                    <TextBlock Text="在" VerticalAlignment="Center" />
                    <ci:Field Suffix="秒">
                        <controls:NumberBox MinWidth="120"
                                            VerticalAlignment="Center"
                                            SpinButtonPlacementMode="Inline"
                                            Minimum="1" Maximum="3600"
                                            Value="{Binding Settings.AutoExecuteSeconds, Converter={x:Static ci:NotNaNConverter.Instance}}" />
                    </ci:Field>
                    <TextBlock Text="内自动触发" VerticalAlignment="Center" />
                    <ComboBox MinWidth="120"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding Settings.AutoExecuteTargets}"
                              SelectedIndex="{Binding Settings.AutoExecuteTargetIndex, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:AutoExecuteTarget">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <!-- 提示：当前下拉框里"无事发生"是合法的占位选项 -->
                <TextBlock Margin="24,0,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="提示：下拉框最后一项为「无事发生」：到时间后不执行任何 Action，仅自动关闭弹窗。" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
    </Grid>
</ci:ActionSettingsControlBase>
