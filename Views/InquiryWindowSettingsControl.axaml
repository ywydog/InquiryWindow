<ci:ActionSettingsControlBase x:Class="InquiryWindow.Views.InquiryWindowSettingsControl"
                              x:TypeArguments="settings:InquiryWindowActionSettings"
                              xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:ci="http://classisland.tech/schemas/xaml/core"
                              xmlns:local="clr-namespace:InquiryWindow.Views"
                              xmlns:settings="clr-namespace:InquiryWindow.Models"
                              xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
                              xmlns:helpers="clr-namespace:ClassIsland.Core.Helpers;assembly=ClassIsland.Core">

    <ci:ActionSettingsControlBase.Styles>
        <!-- 让预览和实际弹窗用同一套 Markdown 主题 -->
        <StyleInclude Source="avares://ClassIsland.Core/Themes/RichTextStyles.axaml" />
    </ci:ActionSettingsControlBase.Styles>

    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:InquiryWindowSettingsControl}}">
    <StackPanel Spacing="8">

        <StackPanel Spacing="4">
            <TextBlock Text="窗口标题 (OS 标题栏)" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBox Text="{Binding Settings.WindowTitle, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="弹窗标题 (窗口内顶部)" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBox Text="{Binding Settings.DialogTitle, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="弹窗正文（支持 Markdown）" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBox Text="{Binding Settings.DialogBody, Mode=TwoWay}"
                     Height="80"
                     AcceptsReturn="True"
                     TextWrapping="Wrap" />
            <!-- 预览：实时反映正文 Markdown 渲染结果 -->
            <Border Margin="0,4,0,0" Padding="8" CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                <StackPanel Spacing="4">
                    <TextBlock Text="预览" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <mdxaml:MarkdownScrollViewer
                        Engine="{x:Static helpers:MarkdownConvertHelper.Engine}"
                        Markdown="{Binding Settings.DialogBody}"
                        MaxHeight="160" />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="目标路径 (.exe / 文件 / 文件夹)" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding Settings.TargetPath, Mode=TwoWay}" />
                <Button Grid.Column="1"
                        Content="浏览文件..."
                        Margin="8,0,0,0"
                        Click="OnBrowseFileClick" />
                <Button Grid.Column="2"
                        Content="浏览文件夹..."
                        Margin="8,0,0,0"
                        Click="OnBrowseFolderClick" />
            </Grid>
        </StackPanel>

        <!-- 显示选项 -->
        <StackPanel Spacing="6" Margin="0,8,0,0">
            <CheckBox Content="在弹窗中显示目标路径"
                      IsChecked="{Binding Settings.ShowPath, Mode=TwoWay}" />
            <CheckBox Content="在弹窗中显示目标图标（仅 .exe）"
                      IsChecked="{Binding Settings.ShowIcon, Mode=TwoWay}" />
        </StackPanel>

        <Border Padding="10" CornerRadius="6"
                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
            <TextBlock TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="支持变量：{time} {date} {subject} {nextSubject} — 找不到值时显示为空。" />
        </Border>

    </StackPanel>
    </Grid>
</ci:ActionSettingsControlBase>
